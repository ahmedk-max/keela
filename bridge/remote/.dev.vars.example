# Copy to .dev.vars for local `wrangler dev`. NEVER commit the real .dev.vars.
# KEELA_SA must be the service-account JSON collapsed onto one line.
KEELA_SA={"type":"service_account","project_id":"keela-finance","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@keela-finance.iam.gserviceaccount.com"}
KEELA_PASSWORD=choose-a-strong-password
